// Version.h.in
// Intelligence Matters - SKSE plugin
//
// TEMPLATE FILE. Do NOT edit the generated Version.h - edit this file instead.
// CMake generates Version.h from this template via configure_file(), filling in
// the numbers declared in project(... VERSION x.y.z ...) in CMakeLists.txt.
//
// The version declared in CMakeLists.txt is the SINGLE SOURCE OF TRUTH. It feeds:
//   1. The SKSE plugin declaration (auto-generated by add_commonlibsse_plugin)
//   2. The plugin load log line
//   3. The Papyrus-facing IMPlugin.GetVersion() / GetVersionString()
//
// IMPORTANT: this is the version of the DLL, which is INDEPENDENT of the mod
// version published on Nexus. Bump it when the plugin's native API or behavior
// changes, not when the mod ships a Papyrus-only fix.
//
// Phase 16 - Stage B.1

#pragma once

#include <cstdint>

namespace IMPlugin::Version
{
	inline constexpr std::uint32_t kMajor = @PROJECT_VERSION_MAJOR@;
	inline constexpr std::uint32_t kMinor = @PROJECT_VERSION_MINOR@;
	inline constexpr std::uint32_t kPatch = @PROJECT_VERSION_PATCH@;

	// Human-readable version, e.g. "1.0.0". Used by the log and by
	// IMPlugin.GetVersionString().
	inline constexpr auto kString = "@PROJECT_VERSION@";

	// Name used for the log file (IntelligenceMatters.log) and log lines.
	inline constexpr auto kProjectName = "@PROJECT_NAME@";

	// Packed numeric version for comparison from Papyrus.
	//
	// Encoding: major * 1000000 + minor * 1000 + patch
	//   1.0.0 -> 1000000
	//   1.2.3 -> 1002003
	//
	// Chosen over bit-shifting because Papyrus has no unsigned/bitwise-friendly
	// Int handling, and this stays readable when printed to a log or MCM.
	// Minor and patch must each stay below 1000.
	//
	// Papyrus Int is 32-bit signed - this encoding is safe up to major 2147.
	inline constexpr std::int32_t kPacked =
		static_cast<std::int32_t>(kMajor * 1000000 + kMinor * 1000 + kPatch);
}
